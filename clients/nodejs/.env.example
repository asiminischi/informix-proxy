###############################################################################
# Test client .env — mirrors the root .env but lets you point at
# whatever proxy / DB you want to test against.
#
# Copy this to clients/nodejs/.env and adjust as needed.
###############################################################################

# gRPC proxy address (host running docker-compose)
PROXY_HOST=localhost
PROXY_PORT=50051

# Informix connection details (passed through the proxy's Connect RPC)
INFORMIX_HOST=informix-db
INFORMIX_PORT=9088
INFORMIX_SERVER=informix
INFORMIX_DB=testdb
INFORMIX_USER=informix
INFORMIX_PASSWORD=in4mix

# Pool settings
POOL_SIZE=10
POOL_MIN_IDLE=2
