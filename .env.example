###############################################################################
# Informix gRPC Proxy - Environment Configuration
#
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
#
# NEVER commit .env to version control (already in .gitignore).
###############################################################################

# ─── Informix Database ──────────────────────────────────────────────────────
INFORMIX_HOST=informix-db
INFORMIX_PORT=9088
INFORMIX_SERVER=informix
INFORMIX_DB=testdb
INFORMIX_USER=informix
INFORMIX_PASSWORD=in4mix

# ─── Connection Pool ────────────────────────────────────────────────────────
POOL_SIZE=20
POOL_MIN_IDLE=5
POOL_MAX_LIFETIME=1800000
CONNECTION_TIMEOUT=30000

# ─── gRPC Proxy ─────────────────────────────────────────────────────────────
GRPC_PORT=50051
METRICS_PORT=9090

# ─── JVM Tuning ─────────────────────────────────────────────────────────────
JAVA_OPTS=-Xmx2g -Xms1g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/tmp

# ─── Grafana ─────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
